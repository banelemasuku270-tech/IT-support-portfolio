	<script>
		function loadScriptWhenIdle(url){
			const loadScript = () => {
				const script = document.createElement('script');
				script.type = 'text/javascript';
				script.src = url;
				script.async = true;
				script.onload = () => console.log(`${url} loaded`);
				script.onerror = () => console.log(`${url} error`);
				document.head.appendChild(script);
			};
			if ('requestIdleCallback' in window) {
				requestIdleCallback(() => {
					console.log('Browser is Idle, loading script');
					loadScript();
				});
			} else {
				loadScript();
			}
		};
	</script>
